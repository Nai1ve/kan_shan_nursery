# 看山小苗圃 · 本地开发环境变量示例
# 复制为 infra/.env 后修改。真实密钥不要提交。

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 基础运行模式
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
APP_ENV=development
PROVIDER_MODE=mock
STORAGE_BACKEND=postgres

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 前端与跨域
# 本地调试默认不自动拉起知乎 OAuth，方便先跳过鉴权。
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
KANSHAN_GATEWAY_URL=http://127.0.0.1:8000
KANSHAN_ZHIHU_URL=http://127.0.0.1:8070
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:8000,http://localhost:8000
NEXT_PUBLIC_ZHIHU_OAUTH_AUTO_START=0

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Gateway
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
GATEWAY_REQUEST_TIMEOUT_SECONDS=20
GATEWAY_READY_SERVICES=profile,seed,zhihu,llm,content,sprout,writing,feedback
DEMO_USER_ID=demo-user

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PostgreSQL
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=kanshan
POSTGRES_USER=kanshan
POSTGRES_PASSWORD=kanshan_dev_password
DATABASE_URL=postgresql+psycopg://kanshan:kanshan_dev_password@postgres:5432/kanshan

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Redis
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
REDIS_URL=redis://redis:6379/0

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 知乎 Community / OAuth / Data Platform
# 本地 mock 模式可留空。要调真实知乎能力时改 PROVIDER_MODE=live 并填写。
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ZHIHU_APP_KEY=
ZHIHU_APP_SECRET=
ZHIHU_COMMUNITY_BASE_URL=https://openapi.zhihu.com
ZHIHU_DEFAULT_RING_ID=

ZHIHU_OAUTH_APP_ID=
ZHIHU_OAUTH_APP_KEY=
ZHIHU_OAUTH_REDIRECT_URI=http://127.0.0.1:3000/auth/zhihu/callback
ZHIHU_OAUTH_BASE_URL=https://openapi.zhihu.com
ZHIHU_ACCESS_TOKEN=
ZHIHU_ACCESS_TOKEN_EXPIRES_AT=

ZHIHU_ACCESS_SECRET=
ZHIHU_DATA_PLATFORM_BASE_URL=https://developer.zhihu.com

# 知乎额度与缓存
ZHIHU_QUOTA_HOT_LIST=100
ZHIHU_QUOTA_ZHIHU_SEARCH=1000
ZHIHU_QUOTA_GLOBAL_SEARCH=1000
ZHIHU_QUOTA_DIRECT_ANSWER=100
ZHIHU_CACHE_BACKEND=redis

# OAuth state 签名密钥。本地可用默认值，线上必须换成长随机串。
OAUTH_STATE_SECRET=kanshan-oauth-state-dev-secret

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LLM 服务
# mock = 离线调试；openai_compat = 平台兜底或兼容 OpenAI 的模型服务。
# 用户个人 LLM 配置通过产品页面保存，不写在这里。
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
LLM_PROVIDER_MODE=mock
LLM_DEFAULT_MODEL=zhida-thinking-1p5
LLM_PROMPT_VERSION=v1
LLM_SCHEMA_VERSION=v1
LLM_CACHE_BACKEND=redis
LLM_CACHE_TTL_SECONDS=21600
LLM_REQUEST_TIMEOUT_SECONDS=20
LLM_TRACE_DIR=output/llm-trace
LLM_TRACE_ENABLED=1

# 兼容旧变量名，部署脚本会映射到 OPENAI_COMPAT_*。
LLM_API_BASE_URL=
LLM_API_KEY=

OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=gpt-4o-mini

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 日志
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
KANSHAN_LOG_DIR=output/logs
KANSHAN_LOG_LEVEL=INFO

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 端口映射
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
FRONTEND_PORT=3000
API_GATEWAY_PORT=8000
