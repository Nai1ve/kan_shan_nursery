# 看山小苗圃 · 部署环境变量
# 复制为 .env 后修改

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 前端访问后端的地址（浏览器端使用，必须公网可达）
# 填你的服务器公网 IP 或域名
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
KANSHAN_GATEWAY_URL=http://<你的服务器IP>:8000
KANSHAN_ZHIHU_URL=http://<你的服务器IP>:8070

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Provider 模式
# mock = 模拟数据（测试用，不需要知乎凭证）
# live = 真实知乎 API（需要配置 services/config.yaml）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PROVIDER_MODE=mock

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 存储后端
# memory = 内存（重启丢失数据，测试用）
# postgres = PostgreSQL（数据持久化，生产用）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
STORAGE_BACKEND=postgres

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PostgreSQL（必须改成强密码）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
POSTGRES_DB=kanshan
POSTGRES_USER=kanshan
POSTGRES_PASSWORD=<改成你的强密码>
DATABASE_URL=postgresql+psycopg://kanshan:<改成你的强密码>@postgres:5432/kanshan

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Redis
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
REDIS_URL=redis://redis:6379/0

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 知乎凭证（live 模式必填，去知乎开放平台申请）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ZHIHU_APP_KEY=
ZHIHU_APP_SECRET=
ZHIHU_ACCESS_TOKEN=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LLM 配置（可选）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
LLM_PROVIDER=mock
LLM_API_BASE_URL=
LLM_API_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 端口映射
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
FRONTEND_PORT=3000
API_GATEWAY_PORT=8000
POSTGRES_PORT=5432
