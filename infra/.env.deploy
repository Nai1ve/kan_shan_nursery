# 看山小苗圃 · 线上部署环境变量示例
# 复制为 infra/.env 后修改。真实密钥不要提交。

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 基础运行模式
# 线上接真实知乎能力时使用 live。
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
APP_ENV=production
PROVIDER_MODE=live
STORAGE_BACKEND=postgres

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 前端与跨域
# KANSHAN_GATEWAY_URL 是浏览器访问 gateway 的公网地址。
# KANSHAN_ZHIHU_URL 主要用于前端构建期展示/兼容，不参与主 OAuth 回调。
# NEXT_PUBLIC_ZHIHU_OAUTH_AUTO_START=1 表示线上进入 OAuth 步骤时自动拉起授权。
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
KANSHAN_GATEWAY_URL=http://CHANGE_ME_SERVER_IP:8000
KANSHAN_ZHIHU_URL=http://CHANGE_ME_SERVER_IP:8070
CORS_ORIGINS=http://CHANGE_ME_SERVER_IP:3000,http://CHANGE_ME_SERVER_IP:8000
NEXT_PUBLIC_ZHIHU_OAUTH_AUTO_START=1

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Gateway
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
GATEWAY_REQUEST_TIMEOUT_SECONDS=20
GATEWAY_READY_SERVICES=profile,seed,zhihu,llm,content,sprout,writing,feedback
DEMO_USER_ID=demo-user

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PostgreSQL（必须改成强密码）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
POSTGRES_DB=kanshan
POSTGRES_USER=kanshan
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
DATABASE_URL=postgresql+psycopg://kanshan:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/kanshan
POSTGRES_PORT=5432

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Redis
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
REDIS_URL=redis://redis:6379/0

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 知乎 Community / OAuth / Data Platform
# redirect URI 必须与知乎开放平台登记值完全一致。
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ZHIHU_APP_KEY=CHANGE_ME_ZHIHU_APP_KEY
ZHIHU_APP_SECRET=CHANGE_ME_ZHIHU_APP_SECRET
ZHIHU_COMMUNITY_BASE_URL=https://openapi.zhihu.com
ZHIHU_DEFAULT_RING_ID=CHANGE_ME_RING_ID

ZHIHU_OAUTH_APP_ID=CHANGE_ME_OAUTH_APP_ID
ZHIHU_OAUTH_APP_KEY=CHANGE_ME_OAUTH_APP_KEY
ZHIHU_OAUTH_REDIRECT_URI=http://CHANGE_ME_SERVER_IP:3000/auth/zhihu/callback
ZHIHU_OAUTH_BASE_URL=https://openapi.zhihu.com
ZHIHU_ACCESS_TOKEN=
ZHIHU_ACCESS_TOKEN_EXPIRES_AT=

ZHIHU_ACCESS_SECRET=CHANGE_ME_ZHIHU_ACCESS_SECRET
ZHIHU_DATA_PLATFORM_BASE_URL=https://developer.zhihu.com

# 知乎额度与缓存
ZHIHU_QUOTA_HOT_LIST=100
ZHIHU_QUOTA_ZHIHU_SEARCH=1000
ZHIHU_QUOTA_GLOBAL_SEARCH=1000
ZHIHU_QUOTA_DIRECT_ANSWER=100
ZHIHU_CACHE_BACKEND=redis

# OAuth state 签名密钥，生产环境必须改成长随机串。
OAUTH_STATE_SECRET=CHANGE_ME_RANDOM_LONG_SECRET

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LLM 服务
# 如暂时不用平台兜底模型，可把 LLM_PROVIDER_MODE 改为 mock 并留空 OPENAI_COMPAT_*。
# 用户个人 LLM 配置通过产品页面保存，不写在这里。
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
LLM_PROVIDER_MODE=openai_compat
LLM_DEFAULT_MODEL=zhida-thinking-1p5
LLM_PROMPT_VERSION=v1
LLM_SCHEMA_VERSION=v1
LLM_CACHE_BACKEND=redis
LLM_CACHE_TTL_SECONDS=21600
LLM_REQUEST_TIMEOUT_SECONDS=20
LLM_TRACE_DIR=output/llm-trace
LLM_TRACE_ENABLED=1

# 兼容旧变量名，部署脚本会映射到 OPENAI_COMPAT_*。
LLM_API_BASE_URL=
LLM_API_KEY=

OPENAI_COMPAT_BASE_URL=CHANGE_ME_OPENAI_COMPAT_BASE_URL
OPENAI_COMPAT_API_KEY=CHANGE_ME_OPENAI_COMPAT_API_KEY
OPENAI_COMPAT_MODEL=CHANGE_ME_OPENAI_COMPAT_MODEL

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 日志
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
KANSHAN_LOG_DIR=output/logs
KANSHAN_LOG_LEVEL=INFO

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 端口映射
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
FRONTEND_PORT=3000
API_GATEWAY_PORT=8000
