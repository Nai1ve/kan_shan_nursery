{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kanshan.local/schemas/zhihu.json",
  "title": "Zhihu Adapter Schemas",
  "type": "object",
  "$defs": {
    "ZhihuSourceType": {
      "type": "string",
      "enum": [
        "hot_list",
        "zhihu_search",
        "global_search",
        "following",
        "ring",
        "comment",
        "story",
        "direct_answer"
      ]
    },
    "ZhihuContentItem": {
      "type": "object",
      "required": ["sourceType", "sourceId", "title", "summary", "raw"],
      "additionalProperties": false,
      "properties": {
        "sourceType": { "$ref": "#/$defs/ZhihuSourceType" },
        "sourceId": { "type": "string" },
        "contentType": { "type": "string" },
        "title": { "type": "string" },
        "url": { "type": "string" },
        "author": { "type": "string" },
        "authorAvatar": { "type": "string" },
        "authorBadgeText": { "type": "string" },
        "publishedAt": { "type": "string" },
        "summary": { "type": "string" },
        "rawExcerptHtml": { "type": "string" },
        "fullContent": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "heatScore": { "type": "number", "minimum": 0 },
        "relevanceScore": { "type": "number", "minimum": 0 },
        "rankingScore": { "type": "number", "minimum": 0 },
        "authorityLevel": { "type": "string" },
        "likeCount": { "type": "integer", "minimum": 0 },
        "commentCount": { "type": "integer", "minimum": 0 },
        "favoriteCount": { "type": "integer", "minimum": 0 },
        "shareCount": { "type": "integer", "minimum": 0 },
        "selectedComments": {
          "type": "array",
          "items": { "type": "string" }
        },
        "searchHashId": { "type": "string" },
        "usageNotice": { "type": "string" },
        "raw": true
      }
    },
    "ZhihuAdapterResult": {
      "type": "object",
      "required": ["items", "cache"],
      "additionalProperties": false,
      "properties": {
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/ZhihuContentItem" }
        },
        "cache": { "$ref": "common.json#/$defs/CacheMeta" },
        "quota": { "$ref": "common.json#/$defs/QuotaMeta" }
      }
    },
    "DirectAnswerRequest": {
      "type": "object",
      "required": ["model", "messages"],
      "additionalProperties": false,
      "properties": {
        "model": {
          "type": "string",
          "enum": ["zhida-fast-1p5", "zhida-thinking-1p5", "zhida-agent"]
        },
        "messages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["role", "content"],
            "additionalProperties": false,
            "properties": {
              "role": { "type": "string" },
              "content": { "type": "string" }
            }
          }
        },
        "stream": { "type": "boolean", "default": false }
      }
    },
    "DirectAnswerResponse": {
      "type": "object",
      "required": ["taskId", "model", "content", "finishReason"],
      "additionalProperties": false,
      "properties": {
        "taskId": { "type": "string" },
        "model": { "type": "string" },
        "content": { "type": "string" },
        "reasoningContent": { "type": "string" },
        "finishReason": { "type": "string" },
        "cache": { "$ref": "common.json#/$defs/CacheMeta" },
        "quota": { "$ref": "common.json#/$defs/QuotaMeta" }
      }
    }
  }
}
