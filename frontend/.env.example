# 前端环境变量示例。复制为 .env.local 后修改。
# .env.local 已被 .gitignore 覆盖，可以放任何本地值，不会进 git。

# 后端模式：mock | gateway
# - mock    : 使用 Next.js /api/mock/* 路由（默认，零依赖）
# - gateway : 走真实 api-gateway，需要后端先起来
NEXT_PUBLIC_KANSHAN_BACKEND_MODE=mock

# api-gateway 地址（仅 gateway 模式生效）
NEXT_PUBLIC_KANSHAN_GATEWAY_URL=http://127.0.0.1:8000

# zhihu-adapter 地址（用于登录页"关联知乎账号"按钮触发 OAuth）
NEXT_PUBLIC_ZHIHU_ADAPTER_URL=http://127.0.0.1:8070
